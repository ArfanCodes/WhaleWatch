# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored — your keys never leave this machine.
# In Expo, only vars prefixed EXPO_PUBLIC_ are readable inside the app.

# --- Supabase (Phase 1) ---
# Project Settings -> API -> Project URL
EXPO_PUBLIC_SUPABASE_URL=
# Project Settings -> API -> Project API keys -> "anon" "public" key
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend-only secrets (used by serverless functions, NOT the app) ---
# Project Settings -> API -> "service_role" key (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=

# --- Alchemy (Phase 1) ---
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_SIGNING_KEY=

# --- Anthropic / Claude (Phase 2) ---
ANTHROPIC_API_KEY=
