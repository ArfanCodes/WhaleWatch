# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored — your keys never leave this machine.
# In Expo, only vars prefixed EXPO_PUBLIC_ are readable inside the app.

# --- Supabase ---
# Project Settings -> API -> Project URL
EXPO_PUBLIC_SUPABASE_URL=
# Project Settings -> API -> Project API keys -> "anon" "public" key
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings -> API -> "service_role" key (KEEP SECRET — backend only)
SUPABASE_SERVICE_ROLE_KEY=

# --- Alchemy (whale events) ---
# https://dashboard.alchemy.com -> Apps -> API Keys
ALCHEMY_API_KEY=
# Webhooks -> your webhook -> Signing Key
ALCHEMY_WEBHOOK_SIGNING_KEY=
# Webhooks -> your webhook -> Auth Token
ALCHEMY_AUTH_TOKEN=

# --- Gemini (crowd-mood scoring, free tier) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Firebase Auth ---
# Firebase console -> Project Settings -> Your apps -> Web app -> Config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Firebase console -> Authentication -> Sign-in method -> Google -> Web client ID
EXPO_PUBLIC_FIREBASE_GOOGLE_CLIENT_ID=
